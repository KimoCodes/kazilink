Options -Indexes
DirectoryIndex public/index.php

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Protect non-public application directories when the project root is the web root.
    RewriteRule ^(?:app|database|docs)(?:/|$) - [F,L,NC]
    RewriteRule (^|/)\.(?!well-known/) - [F,L,NC]
    RewriteRule ^(?:composer\.(?:json|lock)|phpunit\.xml(?:\.dist)?|README(?:\.md)?|.*\.sql)$ - [F,L,NC]

    # Expose files that intentionally live under the public document root.
    RewriteRule ^(assets|uploads)/(.*)$ public/$1/$2 [L,NC]

    # Route all application requests through the public front controller.
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^$ public/index.php [L,QSA]

    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ public/index.php [L,QSA]
</IfModule>
